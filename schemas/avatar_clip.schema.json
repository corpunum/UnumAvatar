{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openunum.local/schemas/avatar_clip.schema.json",
  "title": "AvatarBlendshapeClip",
  "type": "object",
  "additionalProperties": false,
  "required": ["clip", "fps", "duration", "frames"],
  "properties": {
    "clip": {"type": "string", "minLength": 1},
    "fps": {"type": "number", "exclusiveMinimum": 0},
    "duration": {"type": "number", "minimum": 0},
    "source": {"type": "string"},
    "audio": {"type": "string"},
    "frames": {
      "type": "array",
      "items": {"$ref": "./avatar_blendshape_frame.schema.json"},
      "minItems": 1
    }
  }
}
