{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openunum.local/schemas/avatar_blendshape_frame.schema.json",
  "title": "AvatarBlendshapeFrame",
  "type": "object",
  "additionalProperties": false,
  "required": ["time", "blendshapes"],
  "properties": {
    "time": {
      "description": "Timestamp from clip start in seconds.",
      "type": "number",
      "minimum": 0
    },
    "blendshapes": {
      "description": "ARKit-compatible blendshape weight map in [0,1].",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "browDownLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "browDownRight": {"type": "number", "minimum": 0, "maximum": 1},
        "browInnerUp": {"type": "number", "minimum": 0, "maximum": 1},
        "browOuterUpLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "browOuterUpRight": {"type": "number", "minimum": 0, "maximum": 1},
        "cheekPuff": {"type": "number", "minimum": 0, "maximum": 1},
        "cheekSquintLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "cheekSquintRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeBlinkLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeBlinkRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookDownLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookDownRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookInLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookInRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookOutLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookOutRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookUpLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeLookUpRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeSquintLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeSquintRight": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeWideLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "eyeWideRight": {"type": "number", "minimum": 0, "maximum": 1},
        "jawForward": {"type": "number", "minimum": 0, "maximum": 1},
        "jawLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "jawOpen": {"type": "number", "minimum": 0, "maximum": 1},
        "jawRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthClose": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthDimpleLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthDimpleRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthFrownLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthFrownRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthFunnel": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthLowerDownLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthLowerDownRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthPressLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthPressRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthPucker": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthRollLower": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthRollUpper": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthShrugLower": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthShrugUpper": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthSmileLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthSmileRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthStretchLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthStretchRight": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthUpperUpLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "mouthUpperUpRight": {"type": "number", "minimum": 0, "maximum": 1},
        "noseSneerLeft": {"type": "number", "minimum": 0, "maximum": 1},
        "noseSneerRight": {"type": "number", "minimum": 0, "maximum": 1},
        "tongueOut": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
